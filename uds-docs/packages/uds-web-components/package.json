{
  "name": "@uds/web-components",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Lit-based UDS Web Components built in parallel with the documentation site.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && esbuild src/register.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/web-components.js",
    "test": "vitest run src/**/*.test.ts"
  },
  "dependencies": {
    "lit": "^3.3.3"
  }
}
