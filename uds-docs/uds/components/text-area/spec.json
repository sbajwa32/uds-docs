{
  "$schema": "../../schemas/spec.schema.json",
  "component": "text-area",
  "title": "Text Area",
  "description": "A text area lets users enter multi-line freeform text.",
  "whenToUse": "Use for comments, descriptions, notes, and other text that can span multiple lines.",
  "whenNotToUse": "For single-line values such as names, emails, or short search queries, use Text Input.",
  "acceptanceCriteria": [
    "Default/hover/focused/active/error-focused states render",
    "Visible label is always present",
    "Helper text and counter render below the field",
    "Error state sets aria-invalid and announces helper text",
    "Textarea resizes vertically without breaking layout"
  ],
  "dependencies": {
    "css": [
      "uds/components/text-area.css"
    ],
    "js": []
  },
  "props": [
    {
      "name": "value",
      "type": "string",
      "description": "Current text value."
    },
    {
      "name": "placeholder",
      "type": "string",
      "description": "Hint text when empty."
    },
    {
      "name": "label",
      "type": "string",
      "required": true,
      "description": "Visible label."
    },
    {
      "name": "helperText",
      "type": "string",
      "description": "Supporting or error text."
    },
    {
      "name": "maxLength",
      "type": "number",
      "description": "Character counter limit."
    },
    {
      "name": "data-state",
      "type": "enum",
      "enum": [
        "default",
        "hover",
        "focused",
        "active",
        "error-focused"
      ],
      "default": "default",
      "description": "Visual state from Figma matrix."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "description": "Disables text entry."
    }
  ],
  "events": [
    {
      "name": "input",
      "description": "Fires as text changes",
      "payload": "{ value: string }"
    },
    {
      "name": "change",
      "description": "Fires after committed value changes",
      "payload": "{ value: string }"
    },
    {
      "name": "focus",
      "description": "Fires on focus",
      "payload": "FocusEvent"
    },
    {
      "name": "blur",
      "description": "Fires on blur",
      "payload": "FocusEvent"
    }
  ],
  "slots": [],
  "states": [
    {
      "name": "default",
      "description": "Resting state",
      "hasVisual": true
    },
    {
      "name": "hover",
