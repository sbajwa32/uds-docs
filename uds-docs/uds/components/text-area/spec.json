{
  "$schema": "../../schemas/spec.schema.json",
  "component": "text-area",
  "title": "Text Area",
  "description": "A text area lets users enter multi-line freeform text.",
  "whenToUse": "Use for comments, descriptions, notes, and other text that can span multiple lines.",
  "whenNotToUse": "For single-line values such as names, emails, or short search queries, use Text Input.",
  "acceptanceCriteria": [
    "Public API uses <udc-text-area> Web Component tag.",
    "Default/hover/focused/active/error-focused states render",
    "Visible label is always present",
    "Helper text and counter render below the field",
    "Error state sets aria-invalid and announces helper text",
    "Textarea resizes vertically without breaking layout"
  ],
  "dependencies": {
    "css": [
      "uds/uds.css"
    ],
    "js": [
      "web-components.js"
    ]
  },
  "props": [
    {
      "name": "name",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Form field name."
    },
    {
      "name": "value",
      "type": "string",
      "default": "",
      "required": false,
      "description": "Current value."
    },
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Visible label."
    },
    {
      "name": "helper-text",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Helper or error text."
    },
    {
      "name": "placeholder",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Placeholder."
    },
    {
      "name": "state",
      "type": "enum",
      "default": "default",
      "required": false,
      "description": "Validation state.",
      "enum": [
        "default",
        "error"
      ]
    },
    {
      "name": "rows",
      "type": "number",
      "default": 4,
      "required": false,
      "description": "Visible rows."
    },
    {
      "name": "required",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Marks required."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Disabled state."
    },
    {
      "name": "max-length",
      "type": "number",
      "default": null,
      "required": false,
      "description": "Character counter max."
    }
  ],
  "events": [
    {
      "name": "udc-input",
      "description": "Fires on input.",
      "payload": "{ value }"
    },
    {
      "name": "udc-change",
      "description": "Fires on committed change.",
      "payload": "{ value }"
    }
  ],
  "slots": [
    {
      "name": "label",
      "description": "Custom label content."
    },
    {
      "name": "helper",
      "description": "Custom helper content."
    }
  ],
  "states": [
    {
      "name": "default",
      "description": "Resting state",
      "hasVisual": true
    },
    {
      "name": "hover",
      "description": "Pointer hover",
      "hasVisual": true
    },
    {
      "name": "focus-visible",
      "description": "Focused text area",
      "hasVisual": true
    },
    {
      "name": "active",
      "description": "Active editing state",
      "hasVisual": true
    },
    {
      "name": "error",
      "description": "Error-focused state",
      "hasVisual": true
    }
  ],
  "contentGuidelines": "Use for multi-line entries such as notes or descriptions. Helper text should explain expected content or limits.",
  "commonlyPairedWith": [
    "label",
    "button",
    "dialog"
  ],
  "dosDonts": {
    "dos": [
      "Use visible labels",
      "Provide character limits when applicable",
      "Use error helper text to explain the fix"
    ],
    "donts": [
      "Do not use for single-line values",
      "Do not rely on placeholder as label",
      "Do not validate on every keystroke"
    ]
  },
  "accessibility": {
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus to/from the text area"
      },
      {
        "key": "Standard text-edit keys",
        "action": "Native multiline text editing"
      }
    ],
    "screenReader": [
      {
        "trigger": "Text area receives focus",
        "announcement": "Label, edit multi-line, helper text; required/error states when present"
      }
    ],
    "wcag": [
      {
        "criterion": "1.3.1",
        "level": "A",
        "howMet": "Visible label is associated with textarea"
      },
      {
        "criterion": "3.3.1",
        "level": "A",
        "howMet": "Error text is visible and described"
      }
    ],
    "contrast": []
  },
