{
  "$schema": "../../schemas/spec.schema.json",
  "component": "checkbox",
  "title": "Checkbox",
  "description": "A checkbox lets users select one or more options from a set.",
  "whenToUse": "Multiple selections from a set. Binary on/off toggles (terms agreement, opt-in).",
  "whenNotToUse": "For mutually exclusive choices, use a radio group instead.",
  "acceptanceCriteria": [
    "Public API uses <udc-checkbox> Web Component tag."
  ],
  "dependencies": {
    "css": [
      "uds/uds.css"
    ],
    "js": [
      "web-components.js"
    ]
  },
  "props": [
    {
      "name": "name",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Form field name."
    },
    {
      "name": "value",
      "type": "string",
      "default": "on",
      "required": false,
      "description": "Submitted value."
    },
    {
      "name": "checked",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Checked state."
    },
    {
      "name": "indeterminate",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Mixed state."
    },
    {
      "name": "required",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Marks required."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Disabled state."
    },
    {
      "name": "state",
      "type": "enum",
      "default": "default",
      "required": false,
      "description": "Validation state.",
      "enum": [
        "default",
        "error"
      ]
    }
  ],
  "events": [
    {
      "name": "udc-change",
      "description": "Fires when checked changes.",
      "payload": "{ checked, value }"
    }
  ],
  "slots": [
    {
      "name": "default",
      "description": "Checkbox label."
    }
  ],
