{
  "$schema": "../../schemas/spec.schema.json",
  "component": "chip",
  "title": "Chip",
  "description": "A chip is a compact, interactive element for filters, input tokens, or selection.",
  "whenToUse": "For filter selection (multi-select filters). For input tokens (tags, emails, assignees). For dropdown triggers in dense UIs.",
  "whenNotToUse": "For status or category labels — use Badge. For primary actions — use Button.",
  "acceptanceCriteria": [
    "Public API uses <udc-chip> Web Component tag."
  ],
  "dependencies": {
    "css": [
      "uds/uds.css"
    ],
    "js": [
      "web-components.js"
    ]
  },
  "props": [
    {
      "name": "variant",
      "type": "enum",
      "default": "filter",
      "required": false,
      "description": "Chip behavior pattern.",
      "enum": [
        "filter",
        "input",
        "dropdown"
      ]
    },
    {
      "name": "selected",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Selected filter state."
    },
    {
      "name": "removable",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Shows dismiss affordance."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Disables interaction."
    }
  ],
  "events": [
    {
      "name": "udc-chip-toggle",
      "description": "Fires when a filter chip changes selected state.",
      "payload": "{ selected, variant }"
    },
    {
      "name": "udc-dismiss",
      "description": "Fires when a removable chip is dismissed.",
      "payload": "{ reason }"
    }
  ],
  "slots": [
    {
      "name": "default",
      "description": "Chip label."
    }
  ],
  "states": [],
  "contentGuidelines": null,
  "commonlyPairedWith": [],
  "dosDonts": {
    "dos": [],
    "donts": []
  },
  "accessibility": {
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus to the chip"
      },
      {
        "key": "Enter / Space",
        "action": "Toggle selection (filter) or open dropdown"
      },
      {
        "key": "Delete / Backspace",
        "action": "Dismiss input-variant chips"
      }
    ],
    "screenReader": [],
    "wcag": [],
    "contrast": []
  },
  "knownIssues": [],
  "performance": null,
  "motion": null,
  "responsive": null,
  "visualHierarchy": null,
  "densityBehavior": null,
  "owner": {
    "designer": "Unassigned",
    "developer": "Unassigned"
  },
  "draft": false,
  "figmaNodeId": "6182:27972",
  "figmaPageNodeId": "5502-7753",
  "storybookSlug": null,
  "_legacyAccessibilityNotes": "aria-selected for filter chips. Dismiss buttons within chips need aria-label."
}
