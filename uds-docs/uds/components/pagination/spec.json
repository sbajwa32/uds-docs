{
  "$schema": "../../schemas/spec.schema.json",
  "component": "pagination",
  "title": "Pagination",
  "description": "Pagination lets users move through pages of results or records.",
  "whenToUse": "Use when content is split into discrete pages and users need positional awareness within the set.",
  "whenNotToUse": "For small lists, show all items. For continuous feeds, consider load more or infinite scrolling patterns outside UDS.",
  "acceptanceCriteria": [
    "Public API uses <udc-pagination> Web Component tag.",
    "Default and active page states render",
    "Current page uses aria-current=\"page\"",
    "Previous/next controls are keyboard reachable",
    "Rows-per-page control is labelled",
    "Page changes emit page-change"
  ],
  "dependencies": {
    "css": [
      "uds/uds.css"
    ],
    "js": [
      "web-components.js"
    ]
  },
  "props": [
    {
      "name": "page",
      "type": "number",
      "default": 1,
      "required": false,
      "description": "Current page."
    },
    {
      "name": "total-pages",
      "type": "number",
      "default": 1,
      "required": false,
      "description": "Total pages."
    }
  ],
  "events": [
    {
      "name": "udc-page-change",
      "description": "Fires when page changes.",
      "payload": "{ page }"
    }
  ],
  "slots": [],
  "states": [
    {
      "name": "default",
      "description": "Available page button",
      "hasVisual": true
    },
    {
      "name": "selected",
      "description": "Current/active page",
      "hasVisual": true
    },
    {
      "name": "focus-visible",
      "description": "Keyboard focus",
      "hasVisual": true
    },
    {
      "name": "disabled",
      "description": "Unavailable navigation",
      "hasVisual": true
    }
  ],
  "contentGuidelines": "Use numeric page labels and concise rows-per-page copy.",
  "commonlyPairedWith": [
    "data-table",
    "data-view"
  ],
  "dosDonts": {
    "dos": [
      "Use aria-current on current page",
      "Keep page controls close to the list/table",
      "Disable unavailable previous/next controls"
    ],
    "donts": [
      "Do not hide total context when available",
      "Do not use pagination for tiny lists",
      "Do not make current page a link to itself"
    ]
  },
  "accessibility": {
    "keyboard": [
