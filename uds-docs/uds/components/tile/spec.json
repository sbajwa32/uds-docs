{
  "$schema": "../../schemas/spec.schema.json",
  "component": "tile",
  "title": "Tile",
  "description": "A selectable tile presents a choice with a label and optional description. Commonly used for mutually exclusive options in a card-like layout.",
  "whenToUse": "For visual, card-like option selection (e.g. \"Upload CSV / Manual Entry / API Sync\"). When you want more prominence than radio buttons.",
  "whenNotToUse": "For simple text-only choices — use radio buttons. For navigation — use nav.",
  "acceptanceCriteria": [
    "Public API uses <udc-tile> Web Component tag."
  ],
  "dependencies": {
    "css": [
      "uds/uds.css"
    ],
    "js": [
      "web-components.js"
    ]
  },
  "props": [
    {
      "name": "label",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Tile title."
    },
    {
      "name": "description",
      "type": "string",
      "default": null,
      "required": false,
      "description": "Supporting body text."
    },
    {
      "name": "selectable",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Allows selection."
    },
    {
      "name": "selected",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Selected state."
    },
    {
      "name": "disabled",
      "type": "boolean",
      "default": false,
      "required": false,
      "description": "Disabled state."
    }
  ],
  "events": [
    {
      "name": "udc-tile-toggle",
      "description": "Fires when selectable tile toggles.",
      "payload": "{ selected }"
    }
  ],
  "slots": [
    {
      "name": "default",
      "description": "Custom tile content."
    }
  ],
  "states": [],
  "contentGuidelines": null,
  "commonlyPairedWith": [],
  "dosDonts": {
    "dos": [],
    "donts": []
  },
  "accessibility": {
    "keyboard": [
      {
        "key": "Tab",
        "action": "Move focus to the tile"
      },
      {
        "key": "Enter / Space",
        "action": "Toggle selection"
      }
    ],
    "screenReader": [],
    "wcag": [],
    "contrast": []
  },
  "knownIssues": [],
  "performance": null,
  "motion": null,
  "responsive": null,
  "visualHierarchy": null,
  "densityBehavior": null,
  "owner": {
    "designer": "Unassigned",
    "developer": "Unassigned"
  },
  "draft": false,
