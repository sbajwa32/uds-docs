    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  }
